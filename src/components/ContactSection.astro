---
import type { Contact } from "../data/content";

interface Props {
	contact: Contact;
}

const { contact } = Astro.props;
---

<section id="contact">
	<!-- Heading -->
	<h2
		data-animate
		class="font-black uppercase leading-none tracking-tight"
		style="font-size: clamp(48px, 7vw, 88px)"
	>
		<span class="block text-white">LET'S WORK</span>
		<span class="block" style="color: #1e1e1e">TOGETHER</span>
	</h2>

	<!-- Form -->
	<form
		id="contact-form"
		data-animate
		data-delay="1"
		novalidate
		class="mt-10 space-y-5"
	>
		<!-- Name + Email row -->
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
			<div class="space-y-1.5">
				<label for="contact-name" class="block text-xs font-medium text-[#888888]">Name</label>
				<input
					type="text"
					id="contact-name"
					name="name"
					placeholder="Your Name"
					autocomplete="name"
					class="w-full cursor-text rounded-xl border border-[#1c1c1c] bg-[#111111] px-4 py-3 text-sm text-white placeholder-[#444444] outline-none transition duration-200 focus:border-[#e85d1c]/50"
				/>
				<p id="name-error" class="hidden text-xs text-red-400"></p>
			</div>
			<div class="space-y-1.5">
				<label for="contact-email" class="block text-xs font-medium text-[#888888]">Email</label>
				<input
					type="email"
					id="contact-email"
					name="email"
					placeholder="your@email.com"
					autocomplete="email"
					class="w-full cursor-text rounded-xl border border-[#1c1c1c] bg-[#111111] px-4 py-3 text-sm text-white placeholder-[#444444] outline-none transition duration-200 focus:border-[#e85d1c]/50"
				/>
				<p id="email-error" class="hidden text-xs text-red-400"></p>
			</div>
		</div>

		<!-- Message -->
		<div class="space-y-1.5">
			<label for="contact-message" class="block text-xs font-medium text-[#888888]">Message</label>
			<textarea
				id="contact-message"
				name="message"
				placeholder="Message"
				rows="5"
				class="w-full cursor-text resize-none rounded-xl border border-[#1c1c1c] bg-[#111111] px-4 py-3 text-sm text-white placeholder-[#444444] outline-none transition duration-200 focus:border-[#e85d1c]/50"
			></textarea>
			<p id="message-error" class="hidden text-xs text-red-400"></p>
		</div>

		<!-- Form-level status (success / error) -->
		<p id="form-status" class="hidden rounded-xl px-4 py-3 text-sm"></p>

		<!-- Submit -->
		<button
			id="submit-btn"
			type="submit"
			class="w-full cursor-pointer rounded-xl bg-[#e85d1c] py-4 text-sm font-semibold text-white transition duration-200 hover:bg-[#d44f0f] active:bg-[#c04409] disabled:cursor-not-allowed disabled:opacity-50"
		>
			Submit
		</button>
	</form>
</section>

<script>
	import emailjs from "@emailjs/browser";

	const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID as string;
	const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID as string;
	const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY as string;

	const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

	function showError(el: HTMLElement, msg: string) {
		el.textContent = msg;
		el.classList.remove("hidden");
	}

	function clearError(el: HTMLElement) {
		el.textContent = "";
		el.classList.add("hidden");
	}

	function validateName(val: string): string | null {
		if (!val.trim()) return "Name is required.";
		if (val.trim().length < 2) return "Name must be at least 2 characters.";
		return null;
	}

	function validateEmail(val: string): string | null {
		if (!val.trim()) return "Email is required.";
		if (!EMAIL_RE.test(val.trim())) return "Please enter a valid email address.";
		return null;
	}

	function validateMessage(val: string): string | null {
		if (!val.trim()) return "Message is required.";
		if (val.trim().length < 10) return "Message must be at least 10 characters.";
		return null;
	}

	function init() {
		const form = document.getElementById("contact-form") as HTMLFormElement | null;
		if (!form) return;

		const nameInput = document.getElementById("contact-name") as HTMLInputElement;
		const emailInput = document.getElementById("contact-email") as HTMLInputElement;
		const msgInput = document.getElementById("contact-message") as HTMLTextAreaElement;
		const nameError = document.getElementById("name-error") as HTMLParagraphElement;
		const emailError = document.getElementById("email-error") as HTMLParagraphElement;
		const msgError = document.getElementById("message-error") as HTMLParagraphElement;
		const statusEl = document.getElementById("form-status") as HTMLParagraphElement;
		const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

		// Blur-time validation for real-time feedback
		nameInput.addEventListener("blur", () => {
			const err = validateName(nameInput.value);
			err ? showError(nameError, err) : clearError(nameError);
		});
		emailInput.addEventListener("blur", () => {
			const err = validateEmail(emailInput.value);
			err ? showError(emailError, err) : clearError(emailError);
		});
		msgInput.addEventListener("blur", () => {
			const err = validateMessage(msgInput.value);
			err ? showError(msgError, err) : clearError(msgError);
		});

		// Clear error as user types after a field has been marked invalid
		nameInput.addEventListener("input", () => {
			if (!nameError.classList.contains("hidden")) {
				const err = validateName(nameInput.value);
				err ? showError(nameError, err) : clearError(nameError);
			}
		});
		emailInput.addEventListener("input", () => {
			if (!emailError.classList.contains("hidden")) {
				const err = validateEmail(emailInput.value);
				err ? showError(emailError, err) : clearError(emailError);
			}
		});
		msgInput.addEventListener("input", () => {
			if (!msgError.classList.contains("hidden")) {
				const err = validateMessage(msgInput.value);
				err ? showError(msgError, err) : clearError(msgError);
			}
		});

		form.addEventListener("submit", async (e) => {
			e.preventDefault();

			const nameErr = validateName(nameInput.value);
			const emailErr = validateEmail(emailInput.value);
			const msgErr = validateMessage(msgInput.value);

			nameErr ? showError(nameError, nameErr) : clearError(nameError);
			emailErr ? showError(emailError, emailErr) : clearError(emailError);
			msgErr ? showError(msgError, msgErr) : clearError(msgError);

			if (nameErr || emailErr || msgErr) return;

			submitBtn.disabled = true;
			submitBtn.textContent = "Sending…";
			statusEl.classList.add("hidden");

			try {
				await emailjs.send(
					SERVICE_ID,
					TEMPLATE_ID,
					{
						name: nameInput.value.trim(),
						email: emailInput.value.trim(),
						message: msgInput.value.trim(),
					},
					{ publicKey: PUBLIC_KEY }
				);

				statusEl.textContent = "Message sent! I'll get back to you soon.";
				statusEl.className =
					"rounded-xl border border-green-800/40 bg-green-900/20 px-4 py-3 text-sm text-green-400 mb-4!";
				statusEl.classList.remove("hidden");
				form.reset();
			} catch {
				statusEl.textContent =
					"Something went wrong. Please try again or email me directly.";
				statusEl.className =
					"rounded-xl border border-red-800/40 bg-red-900/20 px-4 py-3 text-sm text-red-400 mb-4!";
				statusEl.classList.remove("hidden");
			} finally {
				submitBtn.disabled = false;
				submitBtn.textContent = "Submit";
			}
		});
	}

	document.addEventListener("astro:page-load", init);
</script>
