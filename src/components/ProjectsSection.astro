---
import { Icon } from 'astro-icon/components';
import type { Project } from "../data/content";

interface Props {
	projects: Project[];
}

const { projects } = Astro.props;
---

<section id="projects">
	<!-- Heading -->
	<h2 class="font-black uppercase leading-none tracking-tight mb-4" data-animate style="font-size: clamp(48px, 7vw, 88px)">
		<span class="block text-white">RECENT</span>
		<span class="block" style="color: #1e1e1e">PROJECTS</span>
	</h2>

	<!-- Project list -->
	<div class="mt-10 divide-y divide-[#1c1c1c]">
		{projects.map((project, i) => {
			const Tag = project.link ? 'a' : 'div';
			return (
				<Tag
					href={project.link?.href}
					target={project.link ? "_blank" : undefined}
					rel={project.link ? "noreferrer noopener" : undefined}
					aria-label={project.link ? `Visit ${project.title}` : undefined}
					data-animate
				data-delay={Math.min(i + 1, 5)}
				class="group flex items-start gap-5 py-7 -mx-3 px-3 rounded-xl transition-colors duration-200 hover:bg-[#0e0e0e]"
				>
					<!-- Index block -->
					<div class="flex h-14 w-16 shrink-0 items-center justify-center rounded-xl border border-[#1c1c1c] bg-[#111111] transition-colors duration-200 group-hover:border-[#e85d1c]/30">
						<span class="text-xs font-bold text-[#333333] transition-colors duration-200 group-hover:text-[#e85d1c]/60">0{i + 1}</span>
					</div>

					<!-- Content -->
					<div class="flex-1 min-w-0">
						<h3 class="text-lg font-semibold leading-tight text-white mb-4">{project.title}</h3>
						<p class="mt-2.5 text-sm leading-relaxed text-[#777777]">{project.description}</p>
						{project.points.length > 0 && (
							<ul class="mt-3 space-y-1">
								{project.points.map((point) => (
									<li class="flex gap-2 text-sm text-[#666666]">
										<span class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-[#e85d1c]/60"></span>
										<span class="leading-relaxed">{point}</span>
									</li>
								))}
							</ul>
						)}
					</div>

					<!-- Arrow -->
					<div class={`shrink-0 pt-1 transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 ${project.link ? 'text-[#e85d1c]' : 'text-[#333333] group-hover:text-[#e85d1c]/40'}`}>
						<Icon name="lucide:arrow-up-right" width="20" height="20" />
					</div>
				</Tag>
			);
		})}
	</div>
</section>
