---
import { Icon } from 'astro-icon/components';
import type { Experience } from "../data/content";

interface Props {
	experiences: Experience[];
}

const { experiences } = Astro.props;
---

<section id="experience">
	<!-- Heading -->
	<h2 class="font-black uppercase leading-none tracking-tight mb-4" data-animate style="font-size: clamp(44px, 6.5vw, 82px)">
		<span class="block text-white">5+ YEARS OF</span>
		<span class="block" style="color: #1e1e1e">EXPERIENCE</span>
	</h2>

	<!-- Experience list -->
	<div class="mt-10 divide-y divide-[#1c1c1c]">
		{experiences.map((item, i) => (
			<div
				data-animate
				data-delay={Math.min(i + 1, 5)}
				class="group flex items-start justify-between gap-4 py-7 transition-colors duration-200 hover:bg-[#0e0e0e] -mx-3 px-3 rounded-xl"
			>
				<div class="flex-1 min-w-0">
					<h3 class="text-lg font-semibold leading-tight text-white mb-4">{item.title}</h3>
					<ul class="mt-3 space-y-1.5 mb-4">
						{item.bullets.map((bullet) => (
							<li class="flex gap-2 text-sm text-[#777777]">
								<span class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-[#e85d1c]/60"></span>
								<span class="leading-relaxed">{bullet}</span>
							</li>
						))}
					</ul>
					<p class="mt-3 text-xs text-[#555555]">{item.period}</p>
				</div>
				<div class="shrink-0 pt-1 text-[#e85d1c] transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
					<Icon name="lucide:arrow-up-right" width="18" height="18" />
				</div>
			</div>
		))}
	</div>
</section>
